# ─── Telegram Bot ────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USER_IDS=

# ─── Ollama (local LLM — fast, simple tasks) ──────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ─── Groq API (cloud LLM — complex tasks, code generation) ────────────────────
# Get your free API key at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# For Gmail: use an App Password from https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=your_email@gmail.com

# ─── Notion ───────────────────────────────────────────────────────────────────
# Create an integration at: https://www.notion.so/my-integrations
NOTION_API_KEY=secret_your_notion_api_key_here
# The ID of the database where pages will be created (from the URL)
NOTION_DATABASE_ID=your_notion_database_id_here

# ─── GitHub ───────────────────────────────────────────────────────────────────
# Create a token at: https://github.com/settings/tokens (needs repo scope)
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_USERNAME=your_github_username

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ─── Security ────────────────────────────────────────────────────────────────
COMMAND_TIMEOUT=30000
ALLOWED_PATHS=C:\Users
REQUIRE_CONFIRMATION=false
