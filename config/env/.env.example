# ─── Telegram Bot ────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USER_IDS=

# ─── Ollama ──────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ─── Security ────────────────────────────────────────────────────────────────
# Maximum command execution timeout in milliseconds (default: 30000)
COMMAND_TIMEOUT=30000
# Allowed base paths for file operations (comma-separated)
ALLOWED_PATHS=C:\Users
# Enable dangerous command confirmation (true/false)
REQUIRE_CONFIRMATION=true
